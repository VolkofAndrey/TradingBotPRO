# .env.example — скопируй в .env и заполни реальными значениями
# НЕ КОММИТЬ .env в git!

# Токен T-Инвестиций (tinkoff-invest-api)
BOT_TINKOFF_TOKEN=your_token_here

# ID торгового счёта (получить: tinkoff/sandbox или реальный счёт)
BOT_TINKOFF_ACCOUNT_ID=your_account_id_here

# Опционально: переопределить инструмент без правки YAML
# BOT_FIGI=FUTSI0325000
